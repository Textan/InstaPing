INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
TARGET_USERNAME=account_to_monitor
BARK_URL=https://api.day.app/YOUR_BARK_KEY
ENCRYPTION_KEY=generate_with_fernet

# Railway should mount a volume at /data.
DATA_DIR=/data
POLL_INTERVAL_SECONDS=180
INITIAL_BACKFILL=false

# Target account activity scan limits.
MAX_FEED_ITEMS=12
MAX_REELS=12
MAX_STORIES=20

# Inbound interaction scan limits.
MAX_OWN_FEED_ITEMS=12
MAX_OWN_REELS=12
MAX_STORY_VIEWERS=200
MAX_MEDIA_LIKERS=200
MAX_MEDIA_COMMENTS=50

# Dropbox app-folder storage.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_REMOTE_DIR=InstaPing

# Optional testing switch.
DRY_RUN=false
